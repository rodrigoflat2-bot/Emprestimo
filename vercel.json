{
  "version": 2,
  "builds": [
    {
      "src": "api/health.js",
      "use": "@vercel/node"
    },
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/health", "dest": "api/health.js" },
    { "src": "/style.css", "dest": "/public/style.css" },
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
